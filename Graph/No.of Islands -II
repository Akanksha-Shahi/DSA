// No.of Islands -II
bool isValid( int row, int col, int n, int m){
    return row>=0 && row<n && col>=0 && col<m;
}
vector<int>no_ofIslands(int n, int m, vector<vector<int>>&operators){
    DisJoint ds(n*m);
    int vis[n][m];
    memset(vis,0,sizeof vis);
    int count =0;
    vector<int> ans;
    for(auto it: operators){
        int row =it[0];
        int col =it[1];
        if(vis[row][col]==1){
            ans.push_back(count);
            continue;
        }
        vis[row][col]=1;
        count++;
        int dr[]={-1,0,1,0};
        int dc[]= { 0,1,0,-1};
        for( int i =0; i<4; i++){
            int nrow = row + dr[i];
            int ncol = col + dc[i];
            if( nrow>=0 && nrow<n && ncol>=0 && ncol<m && vis[nrow][ncol]==1){
                int nodeNo = row*m + col;
                int adjNodeNo = nrow*m + ncol;
                if(ds.findUpar(nodeNo) != ds.findUpar(adjNodeNo)){
                    count--;
                    ds.unionBySize(nodeNo, adjNodeNo);
                }
            }
        }
    }
    return ans;
}
