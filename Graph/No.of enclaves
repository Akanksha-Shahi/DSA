// No.of Enclaves
#include <bits/stdc++.h>
using namespace std;
int numEnclaves(vector<vector<int>>&grid){
    queue<pair<int, int>> q;
    int n = grid.size();
    int m = grid[0].size();
    int vis[n][m]={0};
    for( int i =0; i<n; i++){
        for( intj =0; j<m; j++){
            if(i==0 || j==0 ||i==n-1 || j==m-1){
                if(grid[i][j]==1){
                    q.push({i,j});
                    vis[i][j]=1;
                }
            }
        }
    }
    int delRow[] = {-1,0,1,0};
    int delCol[] = {0,1,0,-1};
    while(!q.empty()){
        int row = q.front().first;
        int col = q.front().second;
        q.pop();
        for( int delRow=-1; delRow<=1; delRow++){
            for( int delCol=-1; delCol<=1; delCol++){
                if(delRow==0 && delCol==0) continue;
                int nrow = row+delRow;
                int ncol = col+delCol;
                if(nrow>=0 && nrow<n && ncol>=0 && ncol<m && !vis[nrow][ncol] && grid[nrow][ncol]==1){
                    vis[nrow][ncol]=1;
                    q.push({nrow,ncol});
                }
            }
        }
    }
    int count =0;
    for( int i =0; i<n; i++){
        for( int j =0; j<m; j++){
            if(!vis[i][j] && grid[i][j]==1) count++;
        }
    }
    return count;
}    

