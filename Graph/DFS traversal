// Depth First Search 
void dfs(int node, vector<int> adj[], int vis[],vector<int> &ls){
    vis[node]=1;
    ls.push_back(node);
    for(auto it: adj[node]){
        if(!vis[it]){
            dfs(it, adj, vis, ls);
        }
    }
}
vector<int> dfs1(int V, vector<int> adj[]){
    int vis[V]={0}; // visited array
    int start =0;
    vector<int> ls;
    dfs(start, adj, vis, ls)
}
