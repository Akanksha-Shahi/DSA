// Remove Outermost Parentheses
// brute:
#include <bits/stdc++.h>
using namespace std;
class Solution{
    public:
        string removeOuter( string& s){
            string ans ="";
            stack<char> st;
            for(char ch: s){
                if( ch == ')') st.pop();
                if(!(st.empty())) ans += ch;
                if( ch =='(') st.push(ch);
            }
            return ans;
        }

}
// Optimal
string removeouter1( string s){
    string ans ="";
    int count =0;
    for(char ch:s){
        if( ch ==')') count--;
        if( count>0) ans+=ch;
        if( ch=='()') count++;
    }
    return ans;
}
