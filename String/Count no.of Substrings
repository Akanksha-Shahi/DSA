// Count no.of Substrings
long long countSubstr( string s){
    int n = s.length();
    long long ans =0;
    for( int i =0; i<n; i++){
        string temp ="";
        for( int j =i; j<n; j++){
            temp+=s[j];
            cout<<temp<< " ";
            ans++;
        }
        cout<<endl;
    }
    return ans;
}
// trick
long long countSubStr1( string s){
    long long n =s.length();
    return (n*(n+1))/2;
}
