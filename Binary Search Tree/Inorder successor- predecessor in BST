// successor
Node* inorderSuccess(Node* root, Node* p){
    Node* successor = NULL;
    while( root != NULL){
        if( p->val >= root->val) root = root->right;
        else {
            successor = root;
             root= root->left;
        }
    }
    return successor;
}
// predecessor
Node* inorderPredecessor( Node* root, Node* p){
    Node* predecessor = NULL;
    while(root!= NULL){
        if( root->val >= p->val) root = root->left;
        else{
            predecessor= root;
            root= root->right;
        }
    }
    return predecessor;
}
