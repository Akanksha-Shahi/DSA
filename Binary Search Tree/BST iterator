class BSTiterator{
    stack<Node*> myStack;
public:
    BSTiterator(Node* root) { pushAll(root);}    
    bool hasNext() return !myStack.empty();
    int next (){
        Node* tmpNode = myStack.top();
        myStack.pop();
        pushAll(tmpNode->right);
        return tmpNode->val;
    }
private:
    void pushAll(Node* node){
        for(; node!= NULL ; myStack.push(node), node = node->left);
    }    
}
