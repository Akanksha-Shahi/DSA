// Search in a binary search tree
#include <bits/stdc++.h>
using namespace std;
struct Node{
    int data;
    Node* left = NULL;
    Node* right = NULL;
    Node( int val){
        data = val;
    }
};    
Node* searchBST(Node* root, int val){
    while(root != NULL && root->val != val){
        root= val<root->val? root->left: root->right;
    }
    return root;
}
