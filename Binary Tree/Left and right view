#include <bits/stdc++.h>
using namespace std;
struct Node{
    int data;
    Node* left = NULL;
    Node* right = NULL;
    Node( int val){
        data = val;
    }
};
// Right and Left View of Binary Tree
// Right View
void rightView( Node* root, int level, vector<int> & result){
    if( root == NULL) return;
    if( level == result.size()) result.push_back(root->data);
    rightView(root->right, level+1, result);
    rightView( root->left, level+1, result);
} 

// Left View
void leftView( Node* root, int level, vector<int> & result){
    if( root == NULL) return;
    if( level == result.size()) result.push_back(root->data);
    leftView(root->left, level+1, result);
    leftView( root->right, level+1, result);
} 
