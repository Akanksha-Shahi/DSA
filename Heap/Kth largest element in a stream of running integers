// Kth largest element in a stream of running integers
class Solution{
    priority_queue<int, vector<int>, greater<>> minHeap; // min heap to store the k largest elements
int size;
public:
    Solution( int k , vector<int>& nums){
        size =k;
        for( int n um: nums){
            minHEap.push(num);
            if( minHeap.size()> k) minHeap.pop();
        }
    }
    int add( int val){
        minHeap.push(val);
        if(minHeap.size() > size)minHeap.pop();
        return minHeap.top();
    }
}
